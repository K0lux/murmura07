# DATABASE
DATABASE_URL=postgresql://user:password@localhost:5432/app_db?sslmode=require
# REDIS
REDIS_URL=redis://localhost:6379

# LLM_PROVIDERS
OPENAI_API_KEY=your_openai_api_key
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o-mini
LOCAL_EMBEDDINGS_MODEL_PATH=

# JWT
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# RATE_LIMIT
RATE_LIMIT_GLOBAL_PER_MIN=300
RATE_LIMIT_USER_PER_MIN=120
RATE_LIMIT_ANALYZE_PER_MIN=30
RATE_LIMIT_USER_DAILY=1000

# OPENCLAW
OPENCLAW_BASE_URL=http://localhost:3001
OPENCLAW_API_KEY=

# CHANNELS
TELEGRAM_BOT_TOKEN=
WHATSAPP_API_KEY=
EMAIL_SMTP_URL=
SLACK_BOT_TOKEN=

# MONITORING
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_ENABLED=true
